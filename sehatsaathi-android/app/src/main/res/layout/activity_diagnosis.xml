<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/diag_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/diag_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_location_on" app:tint="@color/diag_text_dark"/>
        <TextView android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:layout_marginStart="8dp"
            android:text="SehatSaathi" android:textColor="@color/diag_text_dark"
            android:textSize="16sp" android:textStyle="bold"/>
        <ImageView android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_person" android:background="@drawable/bg_diag_circle_teal"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:padding="16dp" android:clipToPadding="false">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical">

            <!-- Assessment Complete Badge -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ASSESSMENT COMPLETED" android:background="@drawable/bg_diag_teal_badge"
                android:textColor="@color/diag_text_gray" android:textSize="9sp"
                android:textStyle="bold" android:paddingHorizontal="8dp" android:paddingVertical="4dp"
                android:letterSpacing="0.1"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:text="Diagnostic Summary"
                android:textColor="@color/diag_text_dark" android:textSize="28sp" android:textStyle="bold"/>

            <!-- Patient Header -->
            <TextView android:id="@+id/tvPatientHeader"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="Patient: —"
                android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textStyle="bold"/>

            <Space android:layout_width="match_parent" android:layout_height="20dp"/>

            <!-- ── STEP 02: Analysis Card ─────────────────────────────── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STEP 02: ANALYSIS" android:textColor="@color/diag_text_gray"
                android:textStyle="bold" android:textSize="10sp" android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_diag_card" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LIKELY CONDITION" android:textColor="@color/diag_text_gray"
                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.1"/>

                <!-- Condition name — filled dynamically -->
                <TextView android:id="@+id/tvConditionName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Analysing..." android:textColor="@color/diag_text_dark"
                    android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>

                <!-- Confidence score + bar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvConfidenceScore"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="—% Confidence Score"
                        android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
                <ProgressBar android:id="@+id/confidenceBar"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="0" android:progressTint="@color/diag_text_dark"/>

                <Space android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- Reasoning -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_analytics" app:tint="@color/diag_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Reasoning" android:textColor="@color/diag_text_dark"
                        android:textStyle="bold" android:textSize="12sp" android:layout_marginStart="6dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tvReasoning"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="..." android:textColor="#665D58"
                    android:textSize="13sp" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- ── STEP 03: Refer to Clinic (shown if referral needed) ── -->
            <LinearLayout android:id="@+id/referralCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_diag_btn_primary"
                android:padding="20dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STEP 03: REFERRAL RECOMMENDED"
                    android:textColor="@color/diag_bg" android:textSize="9sp"
                    android:textStyle="bold" android:alpha="0.8" android:letterSpacing="0.1"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_medical_services" app:tint="@color/diag_bg"
                    android:layout_gravity="center_horizontal" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Refer to Clinic" android:textColor="@color/diag_bg"
                    android:textStyle="bold" android:textSize="18sp" android:gravity="center"
                    android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvReferralReason"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/diag_bg" android:textSize="12sp"
                    android:gravity="center" android:layout_marginTop="8dp" android:alpha="0.9"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- ── STEP 04: Treatment ─────────────────────────────────── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STEP 04: RECOMMENDED TREATMENT" android:textColor="@color/diag_text_gray"
                android:textStyle="bold" android:textSize="10sp" android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_diag_card" android:padding="16dp">
                <TextView android:id="@+id/tvTreatment"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="..." android:textColor="#665D58" android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- ── STEP 04b: Next Steps ───────────────────────────────── -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STEP 04: IMMEDIATE GUIDANCE" android:textColor="@color/diag_text_gray"
                android:textStyle="bold" android:textSize="10sp" android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>
            <LinearLayout android:id="@+id/containerNextSteps"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_diag_card"
                android:padding="16dp"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- ── STEP 05: Red Flags ─────────────────────────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/bg_diag_red_flag" android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="top">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_alert" app:tint="@color/diag_red_text" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STEP 05: CRITICAL RED FLAGS" android:textColor="@color/diag_red_text"
                        android:textStyle="bold" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/containerRedFlags"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="12dp"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="32dp"/>

            <!-- Disclaimer + Buttons -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SehatSaathi is an assistive diagnostic tool and does not replace professional medical advice."
                android:textColor="@color/diag_text_gray" android:textSize="10sp"
                android:gravity="center" android:layout_marginBottom="16dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <Button android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="Download Report" android:background="@drawable/bg_diag_btn_outline"
                    android:textColor="@color/diag_text_dark" android:textSize="11sp"
                    android:textAllCaps="false" app:cornerRadius="24dp" android:paddingHorizontal="24dp"/>
                <Space android:layout_width="12dp" android:layout_height="wrap_content"/>
                <Button android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="Share with Doctor" android:backgroundTint="@color/diag_text_dark"
                    android:textColor="@color/diag_bg" android:textSize="11sp"
                    android:textAllCaps="false" app:cornerRadius="24dp" android:paddingHorizontal="24dp"/>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="32dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F1EE"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.constraintlayout.widget.ConstraintLayout>