<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/diag_bg" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_location_on" app:tint="@color/diag_text_dark"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="SehatSaathi" android:textStyle="bold" android:textColor="@color/diag_text_dark" android:textSize="16sp" android:layout_marginStart="4dp"/>
            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_person" android:background="@drawable/bg_diag_circle_teal"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Symptom Clarification" android:textColor="@color/diag_text_dark"
            android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:text="Answer the follow-up questions to refine your diagnosis." android:textColor="@color/diag_text_gray" android:textSize="13sp"/>

        <Space android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Dynamic Question Card (driven by RAG API) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_diag_card"
            android:padding="20dp" android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FOLLOW-UP QUESTION" android:textColor="@color/diag_secondary"
                android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1"/>

            <!-- THIS IS THE DYNAMIC QUESTION TEXT FROM RAG -->
            <TextView
                android:id="@+id/tvCurrentQuestion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Loading question from AI..." android:textColor="@color/diag_text_dark"
                android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <!-- Answer Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btnQ1Yes" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="Yes"
                    android:background="@drawable/bg_diag_selection_inactive"
                    android:textColor="@color/diag_text_gray" android:textSize="13sp"
                    android:textAllCaps="false" app:cornerRadius="8dp"/>
                <Space android:layout_width="8dp" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnQ1No" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="No"
                    android:background="@drawable/bg_diag_selection_inactive"
                    android:textColor="@color/diag_text_gray" android:textSize="13sp"
                    android:textAllCaps="false" app:cornerRadius="8dp"/>
                <Space android:layout_width="8dp" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnQ1Unsure" android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="Unsure"
                    android:background="@drawable/bg_diag_selection_inactive"
                    android:textColor="@color/diag_text_gray" android:textSize="13sp"
                    android:textAllCaps="false" app:cornerRadius="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Loading indicator shown while waiting for next RAG response -->
        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:visibility="gone" android:padding="16dp">
            <ProgressBar android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Analysing with RAG..." android:textColor="@color/diag_text_gray" android:textSize="13sp"/>
        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="16dp"/>

        <!-- Proceed Button -->
        <Button android:id="@+id/btnProceed" android:layout_width="match_parent" android:layout_height="60dp"
            android:text="Submit Answer  →" android:textColor="@android:color/white"
            android:textSize="16sp" android:backgroundTint="@color/diag_text_dark"
            android:textAllCaps="false" app:cornerRadius="12dp" android:textStyle="bold"/>

        <Space android:layout_width="match_parent" android:layout_height="16dp"/>
    </LinearLayout>
</ScrollView>