<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/diag_bg" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ASSESSMENT COMPLETED" android:background="@drawable/bg_diag_teal_badge" android:textColor="@color/diag_secondary" android:textSize="11sp" android:textStyle="bold" android:padding="6dp" />
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
        
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STEP 01: ANALYSIS" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:padding="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Influenza (Type A/B)" android:textColor="@color/diag_text_dark" android:textSize="24sp" android:textStyle="bold" />
            <Space android:layout_width="match_parent" android:layout_height="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reasoning:" android:textColor="@color/diag_text_gray" android:textStyle="bold" android:textSize="12sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Based on sudden onset fever, body aches, and dry cough." android:textColor="#5C5956" android:textSize="13sp" />
            <Space android:layout_width="match_parent" android:layout_height="16dp" />
            <Button android:layout_width="match_parent" android:layout_height="56dp" android:text="Refer to Clinic" android:background="@drawable/bg_diag_btn_primary" android:textColor="@color/diag_bg" android:textAllCaps="false" />
        </LinearLayout>
        
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STEP 02: RED FLAGS" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_red_flag" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STEP 03: CRITICAL RED FLAGS" android:textColor="@color/diag_red_text" android:textStyle="bold" android:textSize="14sp" />
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Difficulty breathing" android:textColor="#5C5956" />
        </LinearLayout>
        
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="Download (PDF)" android:background="@drawable/bg_diag_btn_outline" android:textColor="@color/diag_primary" android:textAllCaps="false" />
            <Space android:layout_width="12dp" android:layout_height="wrap_content" />
            <Button android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="Share" android:background="@drawable/bg_diag_btn_primary" android:textColor="@color/diag_bg" android:textAllCaps="false" />
        </LinearLayout>
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>