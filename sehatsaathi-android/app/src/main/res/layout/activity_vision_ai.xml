<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/diag_bg">

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:padding="16dp" android:clipToPadding="false">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        
        <!-- Header Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_location_on" app:tint="@color/diag_text_dark"/>
            <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="VitalAI" android:textStyle="bold" android:textColor="@color/diag_text_dark" android:textSize="16sp" android:layout_marginStart="4dp"/>
            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_person" android:background="@drawable/bg_diag_circle_teal" />
        </LinearLayout>
        
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
        
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Symptom Clarification" android:textColor="@color/diag_text_dark" android:textSize="28sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:text="Step 1 of the Diagnostic Flow" android:textColor="@color/diag_text_gray" android:textSize="13sp" />
        
        <Space android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- Confidence Bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Confidence" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="10sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="68%" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="10sp"/>
            </LinearLayout>
            <ProgressBar android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="4dp" style="?android:attr/progressBarStyleHorizontal" android:progress="68" android:progressDrawable="@drawable/bg_primary_gradient" />
        </LinearLayout>
        
        <Space android:layout_width="match_parent" android:layout_height="24dp" />
        
        <!-- Question 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VITAL SIGN" android:textColor="@color/diag_secondary" android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Has the fever lasted more than 3 days?" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="6dp"/>
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Yes" android:background="@drawable/bg_diag_selection_active" android:textColor="@android:color/white" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="No" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Unsure" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Question 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:backgroundTint="#F2EAE1" android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DERMATOLOGICAL" android:textColor="@color/diag_text_gray" android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Are there any skin rashes or visible irritations?" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="6dp"/>
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Yes" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="No" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Unsure" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Question 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:backgroundTint="#F9EBEA" android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESPIRATORY" android:textColor="@color/diag_text_gray" android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Experience difficulty breathing while resting?" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="6dp"/>
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Yes" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="No" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
        
        <!-- Question 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:backgroundTint="#EBF5F0" android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEUROLOGICAL" android:textColor="@color/diag_secondary" android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Have you noticed sudden severe headaches?" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="6dp"/>
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Yes" android:background="@drawable/bg_diag_selection_active" android:textColor="@android:color/white" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="No" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Question 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_diag_card" android:padding="16dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GENERAL WELLNESS" android:textColor="@color/diag_text_gray" android:textStyle="bold" android:textSize="9sp" android:letterSpacing="0.1" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Is there a significant loss of appetite?" android:textColor="@color/diag_text_dark" android:textStyle="bold" android:textSize="14sp" android:layout_marginTop="6dp"/>
            <Space android:layout_width="match_parent" android:layout_height="12dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Yes" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="No" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
                <Space android:layout_width="8dp" android:layout_height="wrap_content" />
                <Button android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="Unsure" android:background="@drawable/bg_diag_selection_inactive" android:textColor="@color/diag_text_gray" android:textSize="12sp" android:textAllCaps="false" app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
        
        <!-- Proceed Button -->
        <Button android:id="@+id/btnProceed" android:layout_width="match_parent" android:layout_height="60dp"
            android:text="Proceed to Analysis   →" android:textColor="@android:color/white" android:textSize="16sp" android:backgroundTint="@color/diag_text_dark" android:textAllCaps="false" app:cornerRadius="12dp" android:textStyle="bold" />
            
        <Space android:layout_width="match_parent" android:layout_height="16dp" />
    </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F1EE"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />
</androidx.constraintlayout.widget.ConstraintLayout>