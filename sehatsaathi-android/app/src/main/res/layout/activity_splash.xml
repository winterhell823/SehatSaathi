<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF8F5">

    <!-- Background decorative image -->
    <ImageView
        android:id="@+id/bgPattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.2"
        android:scaleType="centerCrop"
        android:src="@drawable/dna_bg" />

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/mainContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Logo card -->
        <LinearLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:background="@drawable/logo_card_bg"
            android:elevation="6dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_clinical_notes"
                android:tint="#5D4037" />
        </LinearLayout>

        <!-- App name -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SehathSathi"
            android:textColor="#5D4037"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.03"
            android:fontFamily="sans-serif-black" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="EMPATHETIC CLINICAL INTELLIGENCE"
            android:textColor="#705C55"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium" />

        <!-- Feature card -->
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_offline_pin"
                    android:tint="#5D4037" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Offline AI Health"
                    android:textColor="#5D4037"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:background="#1A5D4037" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Secure clinical decisions, even without connectivity."
                android:textColor="#4D4639"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Progress section -->
        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="6dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="false"
                android:max="100"
                android:progress="33"
                android:progressTint="#5D4037"
                android:progressBackgroundTint="#E7E2DF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="INITIALIZING AUTHORITY"
                android:textColor="#85736E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_shield_heart"
                android:tint="#705C55" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="CLINICAL AUTHORITY"
                android:textColor="#705C55"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="© 2024 SehathSathi. All Data Encrypted Locally."
            android:textColor="#804D4639"
            android:textSize="9sp" />
    </LinearLayout>

</RelativeLayout>